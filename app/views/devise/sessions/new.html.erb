<div style="display: flex; flex-direction: column; align-items: center; padding: 40px 20px;">
  <h2 style="font-size: 20px; font-weight: bold; margin-bottom: 24px;">ログイン</h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div style="width: 280px; margin-bottom: 12px;">
      <%= f.email_field :email, placeholder: "メールアドレス", autofocus: true, autocomplete: "email",
          style: "width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size: 14px;" %>
    </div>

    <div style="width: 280px; margin-bottom: 20px;">
      <%= f.password_field :password, placeholder: "パスワード", autocomplete: "current-password",
          style: "width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size: 14px;" %>
    </div>

    <div style="width: 280px;">
      <%= f.submit "ログイン", style: "width: 100%; padding: 12px; background-color: #1a73e8; color: white; border: none; border-radius: 4px; font-size: 16px; cursor: pointer;" %>
    </div>
  <% end %>

  <div style="margin-top: 20px; display: flex; gap: 24px;">
    <%= link_to "アカウント作成", new_user_registration_path, style: "color: #1a73e8; font-size: 14px;" %>
    <%= link_to "パスワードを忘れた方はこちら", new_user_password_path, style: "color: #1a73e8; font-size: 14px;" %>
  </div>

  <footer style="position: fixed; bottom: 16px; display: flex; gap: 16px;">
    <%= link_to "利用規約", terms_path, style: "color: #666; font-size: 12px;" %>
    <%= link_to "プライバシーポリシー", privacy_path, style: "color: #666; font-size: 12px;" %>
  </footer>
</div>