<% content_for :page_title do %>
  履歴詳細
<% end %>

<% content_for :back_button do %>
  <%= link_to hands_path, style: "text-decoration: none; color: #333; font-size: 20px;" do %>
    ↩
  <% end %>
<% end %>

<div style="padding: 16px; max-width: 480px; margin: 0 auto; padding-bottom: 80px;">

  <%# ハンド情報 %>
  <div style="margin-bottom: 24px;">
    <% if @hero_card %>
      <div style="display: flex; gap: 8px; margin-bottom: 12px;">
        <div style="width: 44px; height: 60px; border: 2px solid #ccc; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 16px; background: white;">
          <%= @hero_card.card1 %>
        </div>
        <div style="width: 44px; height: 60px; border: 2px solid #ccc; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 16px; background: white;">
          <%= @hero_card.card2 %>
        </div>
      </div>
    <% end %>

    <p style="font-size: 14px; color: #333; margin-bottom: 4px;">Hero: <%= @hero&.position %></p>
    <p style="font-size: 14px; color: #333; margin-bottom: 16px;">Villain: <%= @villain&.position %></p>

    <% @actions.each do |action| %>
      <p style="font-size: 14px; color: #555;">
        <%= action.player&.is_hero ? "Hero" : "Villain" %>: <%= action.street %> - <%= action.action_type %>
      </p>
    <% end %>
  </div>

  <%# GTOテキスト %>
  <div style="margin-bottom: 16px;">
    <p style="font-size: 14px; font-weight: bold; margin-bottom: 8px;">GTOテキスト</p>
    <textarea id="gto_text" readonly
      style="width: 100%; height: 200px; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size: 12px; font-family: monospace;">
    </textarea>
    <button onclick="copyText()"
      style="margin-top: 8px; width: 100%; padding: 12px; background-color: #1a73e8; color: white; border: none; border-radius: 4px; font-size: 16px; cursor: pointer;">
      テキストをコピー
    </button>
  </div>
</div>

<script>
  window.onload = function() {
    document.getElementById('gto_text').value = generateGTOText();
  }

  function generateGTOText() {
    // GTOテキスト生成は後で実装
    return "GTOテキストはここに表示されます";
  }

  function copyText() {
    const text = document.getElementById('gto_text');
    text.select();
    document.execCommand('copy');
    alert('コピーしました！');
  }
</script>