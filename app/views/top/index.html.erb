<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 20px; text-align: center;">
  <%= image_tag "Logo.png", style: "height: 72px; transform: rotate(-15deg);" %>
  <h2 style="font-size: 32px; font-weight: bold; margin-bottom: 8px;">ハンド記録を始める</h2>
  <p style="color: #666; font-size: 14px; margin-bottom: 32px;">
    ライブトーナメントに特化したハンド履歴管理ツール<br>
    GTOへのテキスト連携も可能
  </p>

  <%= link_to "ログインはこちら", new_user_session_path, style: "display: block; background-color: #1a73e8; color: white; padding: 12px 32px; border-radius: 4px; text-decoration: none; margin-bottom: 12px; width: 200px;" %>
  <%= link_to "新規登録はこちら", new_user_registration_path, style: "display: block; background-color: #1a73e8; color: white; padding: 12px 32px; border-radius: 4px; text-decoration: none; width: 200px;" %>

  <footer style="position: fixed; bottom: 16px; display: flex; gap: 16px;">
    <%= link_to "利用規約", terms_path, style: "color: #666; font-size: 12px;" %>
    <%= link_to "プライバシーポリシー", privacy_path, style: "color: #666; font-size: 12px;" %>
  </footer>
</div>